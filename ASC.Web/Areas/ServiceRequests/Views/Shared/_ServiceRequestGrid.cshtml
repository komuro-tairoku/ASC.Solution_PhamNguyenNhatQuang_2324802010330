@model IEnumerable<ASC.Model.Models.ServiceRequest>
@using ASC.Model.BaseTypes
@{
    var isAudit = ViewBag.IsAudit;
}
<div class="row"></div>
<div class="row padding-top-10px padding-left-20px padding-right-20px">
    <div class="row z-depth-2 table-container" style="width:100%; overflow-x: auto;">
        <table class="highlight centered tblServiceRequests responsive-table" id="@ViewBag.Id">
            <thead style="background-color: #b0bec5; color: white;">
                <tr>
                    <th data-field="RowKey" style="display:none;">RowKey</th>
                    <th data-field="PartitionKey" style="display:none;">PartitionKey</th>
                    <th data-field="PartitionKey" style="font-size: 16px; font-weight: 600; padding: 15px 8px;">User</th>
                    <th data-field="Status" style="font-size: 16px; font-weight: 600; padding: 15px 8px;">Status</th>
                    <th data-field="RequestedDate" style="font-size: 16px; font-weight: 600; padding: 15px 8px;">Requested Date</th>
                    <th data-field="ServiceEngineer" style="font-size: 16px; font-weight: 600; padding: 15px 8px;">Service Engineer</th>
                    @if (isAudit)
                    {
                        <th data-field="RequestedServices" style="font-size: 16px; font-weight: 600; padding: 15px 8px;">Requested Services</th>
                    }
                    <th data-field="Actions" style="font-size: 16px; font-weight: 600; padding: 15px 8px;">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var serviceRequest in Model)
                {
                    <tr style="font-size: 15px; line-height: 2.5;">
                        <td style="display:none;">@serviceRequest.RowKey</td>
                        <td style="display:none;">@serviceRequest.PartitionKey</td>
                        <td style="padding: 12px 8px; font-weight: 500;">
                            @(!serviceRequest.PartitionKey.Contains('-') ?
                                serviceRequest.PartitionKey :
                                serviceRequest.PartitionKey.Split(new char[] { '-' })[0])
                        </td>
                        <td style="padding: 12px 8px;">
                            @switch ((Status)Enum.Parse(typeof(Status), serviceRequest.Status))
                            {
                                case Status.New:
                                case Status.Initiated:
                                case Status.InProgress:
                                case Status.Completed:
                                    <span class="status-badge status-success" style="background-color: #4db6ac; color: white; padding: 6px 12px; border-radius: 20px; font-size: 13px; font-weight: 600; display: inline-block;">@serviceRequest.Status</span>
                                    break;
                                case Status.RequestForInformation:
                                case Status.Pending:
                                case Status.Denied:
                                    <span class="status-badge status-danger" style="background-color: #ef5350; color: white; padding: 6px 12px; border-radius: 20px; font-size: 13px; font-weight: 600; display: inline-block;">@serviceRequest.Status</span>
                                    break;
                                case Status.PendingCustomerApproval:
                                    <span class="status-badge status-warning" style="background-color: #ffa726; color: white; padding: 6px 12px; border-radius: 20px; font-size: 13px; font-weight: 600; display: inline-block;">@serviceRequest.Status</span>
                                    break;
                                default:
                                    break;
                            }
                        </td>
                        <td style="padding: 12px 8px;">
                            @(serviceRequest.RequestedDate == null ? "-" : serviceRequest.
                                RequestedDate.Value.ToString("dd/MM/yyyy"))
                        </td>
                        <td style="padding: 12px 8px;">
                            @(string.IsNullOrWhiteSpace(serviceRequest.ServiceEngineer) ? "-" : serviceRequest.ServiceEngineer)
                        </td>
                        @if (isAudit)
                        {
                            var trimText = String.IsNullOrWhiteSpace(serviceRequest.
                                RequestedServices) ?
                                string.Empty :
                                serviceRequest.RequestedServices.Length > 50 ?
                                string.Format("{0}...", serviceRequest.RequestedServices.
                                Substring(0, 50)) :
                                serviceRequest.RequestedServices;
                            <td style="padding: 12px 8px;" title="@serviceRequest.RequestedServices">@trimText</td>
                        }
                        <td style="padding: 12px 8px;">
                            <a href="/ServiceRequests/ServiceRequest/ServiceRequestDetails/@serviceRequest.RowKey"
                               class="btn-flat waves-effect waves-light teal-text"
                               title="View Details">
                                <i class="material-icons" style="font-size: 24px;">visibility</i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
